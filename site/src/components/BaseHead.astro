---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	ogImage?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage, ogImage } = Astro.props;
const resolvedOgImage = ogImage
	? new URL(ogImage, Astro.site)
	: new URL(image.src, Astro.url);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="google-site-verification" content="dffQ2ib5-mGMNfdAFg19ELrpkpGhxe2JbHi2LRG3U6c" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Google Fonts: Noto Sans JP + Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
	rel="stylesheet"
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="article" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="ja_JP" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@creepyimagex" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />

<!-- View Transitions -->
<ClientRouter />

<!-- Cursor Glow (dark mode + pointer:fine only) -->
<script is:inline>
function initCursorGlow(){
  if(!matchMedia('(pointer:fine)').matches||matchMedia('(prefers-reduced-motion:reduce)').matches)return;
  if(document.querySelector('.cursor-glow'))return;
  var g=document.createElement('div');g.className='cursor-glow';document.body.appendChild(g);
  var x=0,y=0,gx=0,gy=0,af=0;
  function isDark(){return matchMedia('(prefers-color-scheme:dark)').matches}
  function show(){g.style.display=isDark()?'block':'none'}
  show();matchMedia('(prefers-color-scheme:dark)').addEventListener('change',show);
  document.addEventListener('mousemove',function(e){x=e.clientX;y=e.clientY});
  function loop(){gx+=(x-gx)*0.15;gy+=(y-gy)*0.15;g.style.transform='translate('+gx+'px,'+gy+'px) translate(-50%,-50%)';af=requestAnimationFrame(loop)}
  loop();
  document.addEventListener('astro:before-swap',function(){cancelAnimationFrame(af);if(g.parentNode)g.parentNode.removeChild(g)});
}
if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initCursorGlow)}else{initCursorGlow()}
document.addEventListener('astro:page-load',initCursorGlow);
</script>

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-CEZ686BD8J"></script>
<script is:inline>
	window.dataLayer = window.dataLayer || [];
	function gtag(){dataLayer.push(arguments);}
	gtag('js', new Date());
	gtag('config', 'G-CEZ686BD8J');
</script>
