---
---

<section class="article-cta">
	<div class="article-cta-inner">
		<a href="https://x.com/jouji_ai?utm_source=ai-pulse&utm_medium=article-cta" target="_blank" rel="noopener noreferrer" class="cta-item">
			<span class="cta-icon" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
					<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
				</svg>
			</span>
			<span class="cta-label">Xでフォロー</span>
		</a>
		<a href="#newsletter" class="cta-item">
			<span class="cta-icon" aria-hidden="true">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<rect x="2" y="4" width="20" height="16" rx="2" />
					<path d="M22 4L12 13L2 4" />
				</svg>
			</span>
			<span class="cta-label">最新記事をメールで受け取る</span>
		</a>
		<a href="/ai-pulse/blog/" class="cta-item">
			<span class="cta-icon" aria-hidden="true">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M4 19.5A2.5 2.5 0 016.5 17H20" />
					<path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" />
				</svg>
			</span>
			<span class="cta-label">他の記事を読む</span>
		</a>
	</div>
</section>

<style>
	.article-cta {
		max-width: var(--content-width);
		margin: var(--space-12) auto var(--space-4);
	}

	.article-cta-inner {
		display: flex;
		align-items: stretch;
		gap: var(--space-3);
		padding: var(--space-4);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border);
		background: var(--color-bg-sub);
	}

	@media (prefers-color-scheme: dark) {
		.article-cta-inner {
			background: rgba(26, 26, 26, 0.6);
			backdrop-filter: blur(16px);
			-webkit-backdrop-filter: blur(16px);
			border-color: rgba(255, 255, 255, 0.06);
			box-shadow:
				0 0 0 1px rgba(255, 255, 255, 0.03) inset,
				0 4px 24px rgba(0, 0, 0, 0.3);
		}
	}

	.cta-item {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-2);
		padding: var(--space-3) var(--space-4);
		border-radius: var(--radius-md);
		text-decoration: none;
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--color-text-secondary);
		transition: all var(--transition-fast);
	}

	.cta-item:hover {
		color: var(--color-accent);
		background: var(--color-accent-subtle);
	}

	.cta-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.cta-label {
		white-space: nowrap;
	}

	@media (max-width: 640px) {
		.article-cta-inner {
			flex-direction: column;
			gap: var(--space-1);
			padding: var(--space-3);
		}

		.cta-item {
			justify-content: flex-start;
			padding: var(--space-3);
		}
	}
</style>
