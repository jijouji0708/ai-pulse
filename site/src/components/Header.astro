---
---

<header>
	<nav>
		<a href="/ai-pulse/" class="logo">AI Pulse</a>
		<div class="nav-links">
			<a href="/ai-pulse/">ホーム</a>
			<a href="/ai-pulse/blog">ブログ</a>
			<a href="/ai-pulse/about">About</a>
			<a href="https://x.com/creepyimagex" target="_blank" rel="noopener noreferrer" class="icon-link">
				<span class="sr-only">Follow AI Pulse on X</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="currentColor">
					<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background-color: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--color-border);
	}

	@media (prefers-color-scheme: dark) {
		header {
			background-color: rgba(10, 10, 10, 0.8);
		}
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 56px;
	}

	.logo {
		font-weight: 700;
		font-size: 1.125rem;
		color: var(--color-text);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.logo:hover {
		color: var(--color-text);
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.nav-links a {
		font-size: 0.875rem;
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition);
	}

	.nav-links a:hover {
		color: var(--color-text);
	}

	.icon-link {
		display: flex;
		align-items: center;
	}

	@media (max-width: 640px) {
		nav {
			padding: 0 1rem;
		}

		.nav-links {
			gap: 1rem;
		}
	}
</style>
